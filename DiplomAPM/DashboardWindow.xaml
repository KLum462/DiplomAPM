<Window x:Class="DiplomAPM.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АРМ Сотрудника " Height="890" Width="1413"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEE"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D6EAF8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAB8C2"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#005eb8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0,0,-169,0" Cursor="">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Cursor="">
                <TextBlock Text="АРМ" Foreground="White" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,30,0,40"/>

                <Button Content="📋  Все обращения" Style="{StaticResource MenuButton}" Background="#34495E" Foreground="White"/>
                <Button Content="👤  Граждане" Click="BtnCitizens_Click" Style="{StaticResource MenuButton}"/>

                <Button Content="📊  Отчеты" Click="BtnReports_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="📁 Справочники" Click="BtnReferences_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="🛡 Аудит" Click="BtnAudit_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="👥 Персонал" Click="BtnAdmin_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="⚙️  Настройки" Click="BtnSettings_Click" Style="{StaticResource MenuButton}"/>

                <Button Content="🚪 Выход" Style="{StaticResource MenuButton}" VerticalAlignment="Bottom" Margin="0,200,0,0" Click="BtnExit_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Список обращений" FontSize="26" FontWeight="Bold" Foreground="#333"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15" Cursor="">
                <Button Content="+ Добавить" Click="BtnAdd_Click" Style="{StaticResource ActionButton}" Background="#27AE60" Height="40" Margin="0,0,10,0"/>
                <Button Content="🔍 Детали" Click="BtnDetails_Click" Style="{StaticResource ActionButton}" Background="#3498DB" Height="40" Margin="0,0,10,0"/>
                <Button Content="✎ Редактировать" Click="BtnEdit_Click" Style="{StaticResource ActionButton}" Background="#F39C12" Height="40" Margin="0,0,10,0"/>
                <Button Content="🗑 Удалить" Click="BtnDelete_Click" Style="{StaticResource ActionButton}" Background="#E74C3C" Height="40" Margin="0,0,10,0"/>

                <Button Content="📊 В Excel" Click="BtnExport_Click" Style="{StaticResource ActionButton}" Background="#217346" Margin="10,0,10,0" Height="40"/>
                <Button Content="🖨 Печать" Click="BtnPrint_Click" Style="{StaticResource ActionButton}" Background="#8E44AD" Margin="0,0,10,0" Height="40"/>
                <Button Content="↻ Обновить" Click="BtnRefresh_Click" Style="{StaticResource ActionButton}" Background="#95A5A6" Height="40"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Заявитель:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold" FontSize="14"/>
                <TextBox x:Name="txtFilterFio" Width="150" Height="30" Margin="0,0,15,0" Padding="5" VerticalContentAlignment="Center" ToolTip="Введите часть ФИО"/>

                <TextBlock Text="Категория:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold" FontSize="14"/>
                <ComboBox x:Name="cmbFilterCategory" Width="150" Height="30" Margin="0,0,15,0" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryName" VerticalContentAlignment="Center"/>

                <TextBlock Text="Дата от:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold" FontSize="14"/>
                <DatePicker x:Name="dpFilterFrom" Width="110" Height="30" Margin="0,0,15,0" VerticalContentAlignment="Center"/>

                <TextBlock Text="До:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold" FontSize="14"/>
                <DatePicker x:Name="dpFilterTo" Width="110" Height="30" Margin="0,0,15,0" VerticalContentAlignment="Center"/>

                <Button Content="Найти" Click="BtnFilter_Click" Width="80" Height="30" Margin="0,0,5,0" Background="#2980B9" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                <Button Content="Сбросить" Click="BtnResetFilter_Click" Width="80" Height="30" Background="#95A5A6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <DataGrid x:Name="dgRequests" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="dgRequests_MouseDoubleClick"/>
            </Border>

        </Grid>
    </Grid>
</Window>