<Window x:Class="DiplomAPM.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="АРМ Сотрудника " Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEE"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAB8C2"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#005eb8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Cursor="">
                <TextBlock Text="АРМ" Foreground="White" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,30,0,40"/>

                <Button Content="📋  Все обращения" Style="{StaticResource MenuButton}" Background="#34495E" Foreground="White"/>
                <Button Content="👤  Граждане" Click="BtnCitizens_Click" Style="{StaticResource MenuButton}"/>
                
                <Button Content="📊  Отчеты" Click="BtnReports_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="📁 Справочники" Click="BtnReferences_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="🛡 Аудит" Click="BtnAudit_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="👥 Персонал" Click="BtnAdmin_Click" Style="{StaticResource MenuButton}"/>
                <Button Content="⚙️  Настройки" Click="BtnSettings_Click" Style="{StaticResource MenuButton}"/>

                <Button Content="🚪 Выход" Style="{StaticResource MenuButton}" VerticalAlignment="Bottom" Margin="0,200,0,0" Click="BtnExit_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Список обращений" FontSize="26" FontWeight="Bold" Foreground="#333"/>
                <TextBox Width="250" Height="35" Margin="30,0,0,0" Padding="10,0" VerticalContentAlignment="Center"
                         BorderThickness="0" Background="White" Text="Поиск..." Foreground="Gray">
                    <TextBox.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
                    </TextBox.Effect>
                </TextBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,10,0,15" Cursor="">
                <Button Content="+ Добавить" Click="BtnAdd_Click" Style="{StaticResource ActionButton}" Background="#27AE60" Height="57" Width="102"  Margin="0,0,20,0"/>
                    <Button Content="🔍 Детали" Click="BtnDetails_Click" 
                Style="{StaticResource ActionButton}" 
                Background="#3498DB" Height="54" Width="120" Margin="0,0,20,0"/>    
                <Button Content="✎ Редактировать" Click="BtnEdit_Click" Style="{StaticResource ActionButton}" Background="#F39C12" Height="54" Width="168" Margin="0,0,20,0"/>
                <Button Content="🗑 Удалить" Click="BtnDelete_Click" Style="{StaticResource ActionButton}" Background="#E74C3C"/>

                <Button Content="📊 В Excel" Click="BtnExport_Click" Style="{StaticResource ActionButton}" Background="#217346" Margin="10,0,20,0" Width="94"/>
                
                <Button Content="↻ Обновить" Click="BtnRefresh_Click" Style="{StaticResource ActionButton}" Background="#95A5A6"/>
            </StackPanel>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>

                <DataGrid x:Name="dgRequests" IsReadOnly="True" SelectionMode="Single" 
          MouseDoubleClick="dgRequests_MouseDoubleClick"/>
            </Border>
        </Grid>
    </Grid>
</Window>