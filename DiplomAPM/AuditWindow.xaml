<Window x:Class="DiplomAPM.AuditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Журнал аудита системы" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🔒 Журнал безопасности" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Тип действия:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <ComboBox x:Name="cbActionType" Width="150" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Вход"/>
                    <ComboBoxItem Content="Удаление"/>
                    <ComboBoxItem Content="Редактирование"/>
                    <ComboBoxItem Content="Создание"/>
                </ComboBox>

                <TextBlock Text="Поиск по описанию:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="20,0,10,0"/>
                <TextBox x:Name="txtSearch" Width="200" TextChanged="Filter_Changed" VerticalContentAlignment="Center" Padding="5"/>

                <Button Content="🔄 Сбросить" Click="BtnReset_Click" Margin="20,0,0,0"
                        Background="#95A5A6" Foreground="White" Padding="15,5" BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgAudit" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="White" RowHeight="35" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding LogID}" Width="50"/>
                <DataGridTextColumn Header="Дата и время" Binding="{Binding ActionDate, StringFormat='dd.MM.yyyy HH:mm:ss'}" Width="150"/>
                <DataGridTextColumn Header="Сотрудник" Binding="{Binding EmployeeFIO}" Width="200"/>
                <DataGridTextColumn Header="Действие" Binding="{Binding ActionType}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Style.Triggers>
                                <Trigger Property="Text" Value="Удаление">
                                    <Setter Property="Foreground" Value="Red"/>
                                </Trigger>
                                <Trigger Property="Text" Value="Вход">
                                    <Setter Property="Foreground" Value="Green"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Детали операции" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>