<Window x:Class="DiplomAPM.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аналитика и отчеты" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Период с:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpStart" Width="120" VerticalContentAlignment="Center"/>

                <TextBlock Text="по:" VerticalAlignment="Center" Margin="20,0,10,0" FontWeight="SemiBold"/>
                <DatePicker x:Name="dpEnd" Width="120" VerticalContentAlignment="Center"/>

                <Button Content="Показать статистику" Click="BtnShow_Click" Margin="30,0,0,0" Padding="20,8"
                        Background="#005eb8" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Style>
            </TabControl.Resources>

            <TabItem Header="📋 Табличные данные">
                <Border Background="White" CornerRadius="8" Padding="10" Margin="0,5,0,0">
                    <DataGrid x:Name="dgStats" BorderThickness="0" AutoGenerateColumns="True" 
                              IsReadOnly="True" ColumnWidth="*" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </Border>
            </TabItem>

            <TabItem Header="📊 Визуализация">
                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,5,0,0">
                    <Grid>
                        <TextBlock x:Name="txtNoData" Text="Нет данных для отображения" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#AAA" FontSize="16"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="chartContainer" Orientation="Horizontal" 
                                        VerticalAlignment="Bottom" HorizontalAlignment="Center" Height="300"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>
        </TabControl>

        <Button Grid.Row="2" Click="BtnExport_Click" HorizontalAlignment="Right" Margin="0,15,0,0"
                Background="#217346" Foreground="White" Height="45" Width="200" Cursor="Hand" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Скачать в Excel" FontWeight="Bold" FontSize="14"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>