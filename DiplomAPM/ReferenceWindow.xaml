<Window x:Class="DiplomAPM.ReferenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление справочниками" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F0F2F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Настройка справочников" FontSize="22" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>

        <TabControl x:Name="tcReferences" Grid.Row="1" SelectionChanged="tcReferences_SelectionChanged">
            <TabItem Header="Категории" Tag="Categories"/>
            <TabItem Header="Статусы" Tag="Statuses"/>
        </TabControl>

        <Border Grid.Row="1" Background="White" CornerRadius="0,0,10,10" Padding="5" Margin="0,30,0,0">
            <DataGrid x:Name="dgData" AutoGenerateColumns="False" IsReadOnly="True" 
                      SelectionChanged="dgData_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                    <DataGridTextColumn Header="Наименование" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBlock Text="Название записи" Foreground="Gray" Margin="0,0,0,5"/>
            <TextBox x:Name="txtValue" Height="35" VerticalContentAlignment="Center" Padding="10,0" Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Content="➕ Новый" Click="BtnNew_Click" Grid.Column="0" Margin="0,0,5,0"
                        Background="#3498DB" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="💾 Сохранить" Click="BtnSave_Click" Grid.Column="1" Margin="5,0,5,0"
                        Background="#27AE60" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0"/>

                <Button Content="🗑 Удалить" Click="BtnDelete_Click" Grid.Column="2" Margin="5,0,0,0"
                        Background="#E74C3C" Foreground="White" Height="40" FontWeight="Bold" BorderThickness="0"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>