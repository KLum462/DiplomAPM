<Window x:Class="DiplomAPM.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление персоналом" Height="550" Width="850"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Список сотрудников" DockPanel.Dock="Top" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
            <Border Background="White" CornerRadius="10" Padding="5">
                <DataGrid x:Name="dgUsers" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgUsers_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FIO}" Width="*"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="100"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20">
            <StackPanel>
                <TextBlock Text="Данные сотрудника" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="ФИО"/>
                <TextBox x:Name="txtFIO" Margin="0,5,0,15" Height="30"/>

                <TextBlock Text="Логин"/>
                <TextBox x:Name="txtLogin" Margin="0,5,0,15" Height="30"/>

                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="pbPassword" Margin="0,5,0,15" Height="30"/>

                <TextBlock Text="Роль доступа"/>
                <ComboBox x:Name="cbRoles" DisplayMemberPath="RoleName" SelectedValuePath="RoleID" Margin="0,5,0,25" Height="30"/>

                <Button Content="Сохранить / Обновить" Click="BtnSave_Click" Background="#27AE60" Foreground="White" Height="40" FontWeight="Bold" Cursor="Hand" Margin="0,0,0,10"/>
                <Button Content="Удалить сотрудника" Click="BtnDelete_Click" Background="#E74C3C" Foreground="White" Height="40" FontWeight="Bold" Cursor="Hand"/>
                <Button Content="Очистить поля" Click="BtnClear_Click" Background="#95A5A6" Foreground="White" Height="30" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>