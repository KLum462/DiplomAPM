<Window x:Class="DiplomAPM.AddCitizenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый гражданин" Height="400" Width="350"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True" WindowStyle="None">

    <Border Background="White" CornerRadius="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Новый заявитель" FontSize="20" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                <TextBlock Text="Регистрация гражданина в базе" FontSize="12" Foreground="#999" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">

                <TextBlock Text="ФИО" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Height="35" Margin="0,0,0,15">
                    <TextBox x:Name="txtFIO" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
                </Border>

                <TextBlock Text="Телефон" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Height="35" Margin="0,0,0,15">
                    <TextBox x:Name="txtPhone" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
                </Border>

                <TextBlock Text="Email (Электронная почта)" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Height="35" Margin="0,0,0,15">
                    <TextBox x:Name="txtEmail" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center" Padding="10,0"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button Content="Отмена" Click="BtnCancel_Click" Width="100" Height="40" Margin="0,0,10,0"
                        Background="#F1F2F6" Foreground="#777" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Добавить" Click="BtnSave_Click" Width="120" Height="40"
                        Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>