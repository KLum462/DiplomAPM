<Window x:Class="DiplomAPM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="White">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36*"/>
            <RowDefinition Height="37*"/>
        </Grid.RowDefinitions>

        <Path Data="M0,100 Q50,150 0,200" Stroke="Black" StrokeThickness="1" 
              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-20,100,0,0" Grid.RowSpan="2"/>

        <StackPanel VerticalAlignment="Top" Margin="40,124,40,0" Grid.RowSpan="2">

            <Border BorderThickness="1" BorderBrush="#888" CornerRadius="12" Height="65" Margin="0,0,0,20">
                <Grid Margin="15,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Логин" Foreground="#AAA" FontSize="12" Margin="0,5,0,0"/>
                    <TextBox x:Name="txtLogin" Grid.Row="1" Text="userxx" FontWeight="SemiBold"/>
                </Grid>
            </Border>

            <Border BorderThickness="1" BorderBrush="#888" CornerRadius="12" Height="65" Margin="0,0,0,30">
                <Grid Margin="15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Пароль" Foreground="#AAA" FontSize="12" Margin="0,5,0,0" Grid.ColumnSpan="2"/>

                    <PasswordBox x:Name="txtPassword" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center"/>

                    <TextBox x:Name="txtPasswordVisible" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0" 
                             Visibility="Collapsed" VerticalAlignment="Center"/>

                    <Button Grid.Column="1" Grid.Row="1" Background="Transparent" BorderThickness="0" 
                            Cursor="Hand" Click="TogglePassword_Click" Focusable="False">
                        <Path Data="M12,4.5C7,4.5 2.73,7.61 1,12c1.73,4.39 6,7.5 11,7.5s9.27-3.11 11-7.5C21.27,7.61 17,4.5 12,4.5z M12,17c-2.76,0-5-2.24-5-5s2.24-5 5-5s5,2.24 5,5S14.76,17 12,17z M12,9c-1.66,0-3,1.34-3,3s1.34,3 3,3s3-1.34 3-3S13.66,9 12,9z" 
                              Fill="Black" Stretch="Uniform" Width="22" Height="14" Opacity="0.6"/>
                    </Button>
                </Grid>
            </Border>

            <Button x:Name="btnLogin" Click="btnLogin_Click" Height="55" Margin="0,0,0,15" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#6C5CE7" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock Text="Войти в систему" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
            </Button>

            <TextBlock x:Name="txtError" Text="Ошибка входа" Foreground="Red" 
                       HorizontalAlignment="Center" Margin="0,15,0,0" Visibility="Hidden"/>

        </StackPanel>
    </Grid>
</Window>