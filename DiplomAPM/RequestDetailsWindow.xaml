<Window x:Class="DiplomAPM.RequestDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали обращения" Height="600" Width="500"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="txtTitle" Text="Обращение №000" FontSize="22" FontWeight="Bold" Foreground="#333"/>
            <Separator Margin="0,10"/>
            <TextBlock x:Name="txtApplicant" Text="Заявитель: Загрузка..." FontSize="14" Margin="0,5"/>
            <TextBlock x:Name="txtCategory" Text="Категория: Загрузка..." FontSize="14" Margin="0,5"/>
            <TextBlock x:Name="txtDescription" Text="Суть: Загрузка..." TextWrapping="Wrap" Foreground="#555" Margin="0,5"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="История обработки" Background="White" Padding="10">
            <ListView x:Name="lvHistory">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Дата" Width="110">
                            <GridViewColumn.DisplayMemberBinding>
                                <Binding Path="ChangeDate" StringFormat="dd.MM.yyyy HH:mm"/>
                            </GridViewColumn.DisplayMemberBinding>
                        </GridViewColumn>
                        <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding StatusName}" Width="100"/>
                        <GridViewColumn Header="Сотрудник" DisplayMemberBinding="{Binding EmployeeFIO}" Width="120"/>
                        <GridViewColumn Header="Комментарий" DisplayMemberBinding="{Binding Comment}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>

        <Button Grid.Row="2" Content="Закрыть" Click="BtnClose_Click" Width="100" Height="35" 
                Background="#95A5A6" Foreground="White" BorderThickness="0" Margin="0,15,0,0"/>
    </Grid>
</Window>